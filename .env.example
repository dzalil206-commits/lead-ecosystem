# Скопируйте этот файл в .env и заполните реальными значениями
# cp .env.example .env

# Случайная строка 32+ символов
# Генерация: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=замените-на-случайную-строку
ADMIN_SECRET_KEY=замените-на-свой-ключ

# Telegram user_id администратора (узнать у @userinfobot)
ADMIN_ID=5062414502

# Публичный URL сайта
BASE_URL=https://tgleadwareon.ru

# Lava.top API — получить на app.lava.top → API Keys
LAVA_API_KEY=вставьте-ключ-из-lava.top

# UUID продуктов из app.lava.top → Products
LAVA_OFFER_START=3139e5ce-5258-4aba-a85d-939b1a986314
LAVA_OFFER_PRO=1b122454-df3b-4d18-b24c-628404dbc9e1
LAVA_OFFER_SCALE=c756763fe-3cd5-403e-837e-c0d32c214160
LAVA_OFFER_MINER=a40a5779-66a2-4efa-881a-a2c0acf7a0f5
LAVA_OFFER_SENDER=57a0f06b-be61-40d0-86f4-7389b1469ce3

# Токены Telegram-ботов (опционально)
NOTIFY_BOT_TOKEN=
REVIEW_BOT_TOKEN=
