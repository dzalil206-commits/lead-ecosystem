# Скопируйте этот файл в .env и заполните реальными значениями
# cp .env.example .env

# Случайная строка 32+ символов (например: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=замените-на-случайную-строку

# Секретный ключ для входа в /admin
ADMIN_SECRET_KEY=замените-на-свой-ключ

# Ваш USDT-кошелёк для приёма оплаты
USDT_WALLET=TXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Telegram user_id администратора
ADMIN_ID=5062414502

# Путь к SQLite базе (по умолчанию в папке проекта)
