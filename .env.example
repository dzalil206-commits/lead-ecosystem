# Скопируйте этот файл в .env и заполните реальными значениями
# cp .env.example .env

# Случайная строка 32+ символов (например: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=замените-на-случайную-строку

# Секретный ключ для входа в /admin
ADMIN_SECRET_KEY=замените-на-свой-ключ

# Ваш USDT-кошелёк для приёма оплаты
USDT_WALLET=TXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Telegram user_id администратора
ADMIN_ID=5062414502

# Путь к SQLite базе (по умолчанию в папке проекта)
# DATABASE=lead_ecosystem.db

# ЮKassa — автоматическая выдача лицензий после оплаты
# Получить на: https://yookassa.ru → Интеграция → Ключи API
YOOKASSA_SHOP_ID=ваш-shop-id
YOOKASSA_SECRET_KEY=ваш-секретный-ключ-юkassa

# Токен для бота отзывов (любая случайная строка, ту же поставить в боте)
REVIEW_BOT_TOKEN=случайный-токен-для-бота

# Публичный URL сайта (нужен для redirect после оплаты)
BASE_URL=https://tgleadwareon.ru

# SMTP для email-уведомлений после оплаты
# Gmail: включить "App Password" в настройках Google-аккаунта
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ваш-gmail@gmail.com
SMTP_PASS=ваш-app-password
SMTP_FROM=noreply@tgleadwareon.ru

LAVA_API_KEY=ваш-api-ключ-lava-top
LAVA_OFFER_START=id-оффера-start
LAVA_OFFER_PRO=id-оффера-pro
LAVA_OFFER_SCALE=id-оффера-scale
LAVA_OFFER_MINER=id-оффера-miner
LAVA_OFFER_SENDER=id-оффера-sender
